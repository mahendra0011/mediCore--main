{
  "name": "medicore",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "install:python": "pip install -r python_backend/requirements.txt",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:python": "cd python_backend && python -m uvicorn app.main:app --reload --port 5000",
    "dev:all": "concurrently \"npm run dev --prefix server\" \"npm run dev:python\" \"npm run dev --prefix client\"",
    "seed": "npm run seed --prefix server",
    "seed:python": "cd python_backend && python -m app.seed",
    "build": "npm run build --prefix client",
    "start:python": "cd python_backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "mongodb": "^7.1.1",
    "rollup": "^4.60.3"
  }
}
