# Server Configuration
PORT=5000
NODE_ENV=production
CLIENT_URL=https://medicore-main-1.onrender.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.avvnhcg.mongodb.net/medicore?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Cloudinary (for file uploads)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# SMTP Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="MediCore Hospital <your-email@gmail.com>"

# Optional: Twilio for SMS (if implementing SMS OTP)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone
